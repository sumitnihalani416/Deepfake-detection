# inference.py
"""
Video-level deepfake detection with frame-by-frame prediction,
temporal smoothing, and confidence aggregation.
"""

import torch
import torch.nn.functional as F
import numpy as np
import cv2
from pathlib import Path
from typing import List, Dict, Tuple, Optional
import logging
from scipy.signal import savgol_filter

from utils.dataset import get_val_transforms

logger = logging.getLogger(__name__)


class DeepfakePredictor:
    """
    Runs frame-level and video-level inference for deepfake detection.
    """

    LABELS = {0: "REAL", 1: "FAKE"}

    def __init__(
        self,
        model: torch.nn.Module,
        face_detector,
        device: Optional[str] = None,
        frames_to_sample: int = 30,
        batch_size: int = 16,
        threshold: float = 0.5,
        aggregation: str = "mean",  # mean | max | weighted_mean
        temporal_smoothing: bool = True,
        smoothing_window: int = 5,
        image_size: int = 224,
    ):
        self.model = model
        self.detector = face_detector
        self.device = device or ("cuda" if torch.cuda.is_available() else "cpu")
        self.model.to(self.device)
        self.model.eval()

        self.frames_to_sample = frames_to_sample
        self.batch_size = batch_size
        self.threshold = threshold
        self.aggregation = aggregation
        self.temporal_smoothing = temporal_smoothing
        self.smoothing_window = smoothing_window
        self.transform = get_val_transforms(image_size)

    # ------------------------------------------------------------------ #
    #  Frame-level                                                          #
    # ------------------------------------------------------------------ #

    def predict_faces(self, face_list: List[np.ndarray]) -> np.ndarray:
        """
        Run inference on a list of face RGB arrays.
        Returns fake probability for each face.
        """
        if not face_list:
            return np.array([])

        tensors = []
        for face in face_list:
            aug = self.transform(image=face)
            tensors.append(aug["image"])

        all_probs = []
        for i in range(0, len(tensors), self.batch_size):
            batch = torch.stack(tensors[i : i + self.batch_size]).to(self.device)
            with torch.no_grad():
                logits = self.model(batch)
                probs = F.softmax(logits, dim=1)[:, 1].cpu().numpy()
            all_probs.extend(probs)

        return np.array(all_probs)

    # ------------------------------------------------------------------ #
    #  Video-level                                                          #
    # ------------------------------------------------------------------ #

    def predict_video(self, video_path: str) -> Dict:
        """
        Full pipeline: sample frames → detect faces → predict → aggregate.

        Returns a result dict with:
            - label: "REAL" | "FAKE"
            - video_score: float [0, 1]  (probability of being FAKE)
            - is_fake: bool
            - confidence: float [0, 1]
            - frame_scores: list of (frame_idx, fake_prob)
            - frame_count: int
            - faces_found: int
        """
        cap = cv2.VideoCapture(video_path)
        if not cap.isOpened():
            raise ValueError(f"Cannot open video: {video_path}")

        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        fps = cap.get(cv2.CAP_PROP_FPS)

        # Sample frame indices
        if total_frames <= self.frames_to_sample:
            frame_indices = list(range(total_frames))
        else:
            step = total_frames / self.frames_to_sample
            frame_indices = [int(i * step) for i in range(self.frames_to_sample)]

        frame_scores = []  # (frame_idx, fake_prob)

        for idx in frame_indices:
            cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
            ret, frame = cap.read()
            if not ret or frame is None:
                continue

            faces = self.detector.detect(frame)
            if not faces:
                continue

            probs = self.predict_faces(faces[:1])  # Primary face only
            if len(probs) > 0:
                frame_scores.append((idx, float(probs[0])))

        cap.release()

        if not frame_scores:
            return self._empty_result(video_path, total_frames)

        frame_idxs = [s[0] for s in frame_scores]
        raw_probs = np.array([s[1] for s in frame_scores])

        # Temporal smoothing
        smoothed = self._smooth(raw_probs)

        # Video-level aggregation
        video_score = self._aggregate(smoothed)
        is_fake = video_score >= self.threshold
        confidence = video_score if is_fake else (1.0 - video_score)

        return {
            "video_path": str(video_path),
            "label": self.LABELS[int(is_fake)],
            "is_fake": bool(is_fake),
            "video_score": float(video_score),
            "confidence": float(confidence),
            "frame_scores": list(zip(frame_idxs, smoothed.tolist())),
            "raw_frame_scores": list(zip(frame_idxs, raw_probs.tolist())),
            "frame_count": total_frames,
            "faces_found": len(frame_scores),
            "fps": fps,
        }

    def _smooth(self, scores: np.ndarray) -> np.ndarray:
        if not self.temporal_smoothing or len(scores) < self.smoothing_window:
            return scores
        window = min(self.smoothing_window, len(scores))
        if window % 2 == 0:
            window -= 1
        if window < 3:
            return scores
        try:
            return savgol_filter(scores, window_length=window, polyorder=2)
        except Exception:
            return scores

    def _aggregate(self, scores: np.ndarray) -> float:
        if self.aggregation == "max":
            return float(np.max(scores))
        elif self.aggregation == "weighted_mean":
            # Weight higher scores more
            weights = np.exp(scores) / np.exp(scores).sum()
            return float(np.dot(weights, scores))
        else:  # mean
            return float(np.mean(scores))

    def _empty_result(self, video_path: str, total_frames: int) -> Dict:
        return {
            "video_path": str(video_path),
            "label": "UNKNOWN",
            "is_fake": None,
            "video_score": None,
            "confidence": 0.0,
            "frame_scores": [],
            "raw_frame_scores": [],
            "frame_count": total_frames,
            "faces_found": 0,
            "fps": 0,
            "error": "No faces detected in video",
        }

    # ------------------------------------------------------------------ #
    #  Annotated video export                                               #
    # ------------------------------------------------------------------ #

    def annotate_video(
        self,
        video_path: str,
        output_path: str,
        result: Optional[Dict] = None,
    ) -> str:
        """Create an annotated copy of the video with per-frame fake scores."""
        if result is None:
            result = self.predict_video(video_path)

        score_lookup = dict(result.get("frame_scores", []))

        cap = cv2.VideoCapture(video_path)
        fps = cap.get(cv2.CAP_PROP_FPS) or 25
        w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
        h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))

        out = cv2.VideoWriter(output_path, cv2.VideoWriter_fourcc(*"mp4v"), fps, (w, h))

        frame_idx = 0
        while True:
            ret, frame = cap.read()
            if not ret:
                break

            score = score_lookup.get(frame_idx)
            if score is not None:
                label = "FAKE" if score >= self.threshold else "REAL"
                color = (0, 0, 255) if label == "FAKE" else (0, 200, 0)
                text = f"{label}: {score:.2f}"
                cv2.rectangle(frame, (10, 10), (250, 50), (0, 0, 0), -1)
                cv2.putText(frame, text, (15, 38), cv2.FONT_HERSHEY_SIMPLEX, 0.9, color, 2)

            out.write(frame)
            frame_idx += 1

        cap.release()
        out.release()
        logger.info(f"Annotated video saved: {output_path}")
        return output_path
