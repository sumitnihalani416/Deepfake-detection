# utils/video_processor.py
"""
Video frame extraction and face preprocessing pipeline.
"""

import cv2
import numpy as np
import os
import logging
from pathlib import Path
from typing import List, Tuple, Optional, Generator
from tqdm import tqdm

logger = logging.getLogger(__name__)


class VideoProcessor:
    """
    Handles video loading, frame sampling, and face extraction pipeline.
    """

    def __init__(
        self,
        face_detector,
        frames_per_video: int = 30,
        face_size: Tuple[int, int] = (224, 224),
        sampling_strategy: str = "uniform",  # uniform, random, keyframe
    ):
        self.detector = face_detector
        self.frames_per_video = frames_per_video
        self.face_size = face_size
        self.sampling_strategy = sampling_strategy

    def get_video_info(self, video_path: str) -> dict:
        """Get basic video metadata."""
        cap = cv2.VideoCapture(video_path)
        if not cap.isOpened():
            raise ValueError(f"Cannot open video: {video_path}")

        info = {
            "fps": cap.get(cv2.CAP_PROP_FPS),
            "frame_count": int(cap.get(cv2.CAP_PROP_FRAME_COUNT)),
            "width": int(cap.get(cv2.CAP_PROP_FRAME_WIDTH)),
            "height": int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT)),
            "duration": cap.get(cv2.CAP_PROP_FRAME_COUNT) / max(cap.get(cv2.CAP_PROP_FPS), 1),
        }
        cap.release()
        return info

    def sample_frame_indices(self, total_frames: int, n_frames: int) -> List[int]:
        """Compute which frame indices to sample."""
        if total_frames <= 0:
            return []

        if self.sampling_strategy == "uniform":
            if total_frames <= n_frames:
                return list(range(total_frames))
            step = total_frames / n_frames
            return [int(i * step) for i in range(n_frames)]

        elif self.sampling_strategy == "random":
            indices = np.random.choice(total_frames, min(n_frames, total_frames), replace=False)
            return sorted(indices.tolist())

        else:  # fallback to uniform
            step = max(1, total_frames // n_frames)
            return list(range(0, total_frames, step))[:n_frames]

    def extract_frames(self, video_path: str) -> Generator[Tuple[int, np.ndarray], None, None]:
        """Generator yielding (frame_idx, bgr_frame) for sampled frames."""
        cap = cv2.VideoCapture(video_path)
        if not cap.isOpened():
            logger.error(f"Cannot open video: {video_path}")
            return

        total_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))
        indices = self.sample_frame_indices(total_frames, self.frames_per_video)

        for idx in indices:
            cap.set(cv2.CAP_PROP_POS_FRAMES, idx)
            ret, frame = cap.read()
            if ret and frame is not None:
                yield idx, frame

        cap.release()

    def extract_faces_from_video(
        self, video_path: str, max_faces_per_frame: int = 1
    ) -> Tuple[List[np.ndarray], List[int]]:
        """
        Extract face crops from a video file.

        Returns:
            faces: list of face images (H, W, 3) in RGB
            frame_indices: corresponding frame index for each face
        """
        faces, frame_idxs = [], []

        for frame_idx, frame in self.extract_frames(video_path):
            detected = self.detector.detect(frame, self.face_size)
            for face in detected[:max_faces_per_frame]:
                faces.append(face)
                frame_idxs.append(frame_idx)

        logger.debug(f"Extracted {len(faces)} faces from {video_path}")
        return faces, frame_idxs

    def preprocess_dataset(
        self,
        dataset_root: str,
        output_root: str,
        label_map: dict = None,
    ) -> dict:
        """
        Preprocess an entire dataset directory structure.

        Expected layout:
            dataset_root/
                real/  (or 'original')
                fake/  (or 'manipulated')

        Saves face crops to output_root/{label}/{video_name}_{idx}.png
        Returns stats dict.
        """
        if label_map is None:
            label_map = {
                "real": 0, "original": 0, "pristine": 0,
                "fake": 1, "manipulated": 1, "altered": 1, "deepfake": 1,
            }

        os.makedirs(output_root, exist_ok=True)
        stats = {"real": 0, "fake": 0, "errors": 0, "no_face": 0}

        dataset_path = Path(dataset_root)
        video_extensions = {".mp4", ".avi", ".mov", ".mkv", ".webm"}

        for class_dir in dataset_path.iterdir():
            if not class_dir.is_dir():
                continue

            class_name = class_dir.name.lower()
            label = label_map.get(class_name, -1)
            if label == -1:
                logger.warning(f"Unknown class directory: {class_name}, skipping.")
                continue

            label_str = "real" if label == 0 else "fake"
            out_class_dir = Path(output_root) / label_str
            out_class_dir.mkdir(parents=True, exist_ok=True)

            video_files = [
                f for f in class_dir.rglob("*") if f.suffix.lower() in video_extensions
            ]

            logger.info(f"Processing {len(video_files)} {label_str} videos...")

            for video_path in tqdm(video_files, desc=f"[{label_str}]"):
                try:
                    faces, _ = self.extract_faces_from_video(str(video_path))
                    if not faces:
                        stats["no_face"] += 1
                        continue

                    for i, face in enumerate(faces):
                        out_path = out_class_dir / f"{video_path.stem}_{i:04d}.png"
                        face_bgr = cv2.cvtColor(face, cv2.COLOR_RGB2BGR)
                        cv2.imwrite(str(out_path), face_bgr)

                    stats[label_str] += len(faces)

                except Exception as e:
                    logger.error(f"Error processing {video_path}: {e}")
                    stats["errors"] += 1

        logger.info(f"Dataset preprocessing complete: {stats}")
        return stats

    def stream_video_faces(self, video_path: str) -> Generator[Tuple[int, np.ndarray], None, None]:
        """
        Generator for streaming face crops during inference.
        Yields (frame_idx, face_rgb_array).
        """
        for frame_idx, frame in self.extract_frames(video_path):
            detected = self.detector.detect(frame, self.face_size)
            for face in detected[:1]:  # Primary face only
                yield frame_idx, face
