# train.py
"""
Training script with staged fine-tuning, mixed precision, and early stopping.
"""

import os
import torch
import torch.nn as nn
import torch.optim as optim
from torch.cuda.amp import GradScaler, autocast
import numpy as np
from pathlib import Path
from tqdm import tqdm
from sklearn.metrics import (
    accuracy_score, f1_score, roc_auc_score, confusion_matrix, classification_report
)
import logging
import json
from datetime import datetime

from configs.config import Config, DEFAULT_CONFIG
from models.detector import build_model
from utils.dataset import build_dataloaders

logging.basicConfig(level=logging.INFO, format="%(asctime)s [%(levelname)s] %(message)s")
logger = logging.getLogger(__name__)


# --------------------------------------------------------------------------- #
#  Metrics helpers                                                               #
# --------------------------------------------------------------------------- #

def evaluate(model, loader, device, criterion):
    model.eval()
    all_preds, all_labels, all_probs, total_loss = [], [], [], 0.0

    with torch.no_grad():
        for images, labels in loader:
            images, labels = images.to(device), labels.to(device)
            logits = model(images)
            loss = criterion(logits, labels)
            total_loss += loss.item()

            probs = torch.softmax(logits, dim=1)[:, 1].cpu().numpy()
            preds = logits.argmax(dim=1).cpu().numpy()

            all_probs.extend(probs)
            all_preds.extend(preds)
            all_labels.extend(labels.cpu().numpy())

    avg_loss = total_loss / len(loader)
    acc = accuracy_score(all_labels, all_preds)
    f1 = f1_score(all_labels, all_preds, average="binary", zero_division=0)
    try:
        auc = roc_auc_score(all_labels, all_probs)
    except ValueError:
        auc = 0.5

    return {"loss": avg_loss, "accuracy": acc, "f1": f1, "auc": auc}


# --------------------------------------------------------------------------- #
#  Trainer                                                                      #
# --------------------------------------------------------------------------- #

class Trainer:
    def __init__(self, config: Config = DEFAULT_CONFIG):
        self.cfg = config
        self.device = torch.device(
            "cuda" if torch.cuda.is_available() else
            "mps" if torch.backends.mps.is_available() else "cpu"
        )
        logger.info(f"Training on device: {self.device}")

        # Reproducibility
        torch.manual_seed(config.seed)
        np.random.seed(config.seed)

        # Output dirs
        self.ckpt_dir = Path(config.checkpoint_dir)
        self.ckpt_dir.mkdir(parents=True, exist_ok=True)
        self.run_name = f"{config.model.architecture}_{datetime.now():%Y%m%d_%H%M%S}"

    def build(self):
        # Model
        self.model = build_model(
            architecture=self.cfg.model.architecture,
            num_classes=self.cfg.model.num_classes,
            pretrained=self.cfg.model.pretrained,
            dropout=self.cfg.model.dropout_rate,
        ).to(self.device)

        # Optionally freeze most of backbone initially
        if hasattr(self.model, "freeze_backbone"):
            self.model.freeze_backbone(n_layers=50)

        # Data loaders
        self.loaders = build_dataloaders(
            data_root=self.cfg.data.dataset_root,
            image_size=self.cfg.model.image_size,
            batch_size=self.cfg.training.batch_size,
            num_workers=self.cfg.data.num_workers,
        )

        # Loss
        class_weights = self.loaders["train"].dataset.get_class_weights().to(self.device)
        self.criterion = nn.CrossEntropyLoss(
            weight=class_weights,
            label_smoothing=self.cfg.training.label_smoothing,
        )

        # Optimizer
        self.optimizer = optim.AdamW(
            filter(lambda p: p.requires_grad, self.model.parameters()),
            lr=self.cfg.training.learning_rate,
            weight_decay=self.cfg.training.weight_decay,
        )

        # Scheduler
        self.scheduler = optim.lr_scheduler.CosineAnnealingLR(
            self.optimizer,
            T_max=self.cfg.training.num_epochs - self.cfg.training.warmup_epochs,
            eta_min=1e-6,
        )

        self.scaler = GradScaler()
        self.best_val_auc = 0.0
        self.patience_counter = 0
        self.history = {"train": [], "val": []}

    def _warmup_lr(self, epoch: int):
        """Linear warmup for first N epochs."""
        if epoch < self.cfg.training.warmup_epochs:
            lr = self.cfg.training.learning_rate * (epoch + 1) / self.cfg.training.warmup_epochs
            for pg in self.optimizer.param_groups:
                pg["lr"] = lr

    def train_epoch(self, epoch: int) -> dict:
        self.model.train()
        all_preds, all_labels, total_loss = [], [], 0.0

        pbar = tqdm(self.loaders["train"], desc=f"Epoch {epoch+1} [Train]")
        for step, (images, labels) in enumerate(pbar):
            images, labels = images.to(self.device), labels.to(self.device)

            self.optimizer.zero_grad()
            with autocast():
                logits = self.model(images)
                loss = self.criterion(logits, labels)

            self.scaler.scale(loss).backward()
            self.scaler.unscale_(self.optimizer)
            nn.utils.clip_grad_norm_(self.model.parameters(), self.cfg.training.gradient_clip)
            self.scaler.step(self.optimizer)
            self.scaler.update()

            total_loss += loss.item()
            preds = logits.argmax(1).detach().cpu().numpy()
            all_preds.extend(preds)
            all_labels.extend(labels.cpu().numpy())
            pbar.set_postfix(loss=f"{loss.item():.4f}")

        acc = accuracy_score(all_labels, all_preds)
        return {"loss": total_loss / len(self.loaders["train"]), "accuracy": acc}

    def train(self):
        logger.info(f"Starting training run: {self.run_name}")
        for epoch in range(self.cfg.training.num_epochs):
            self._warmup_lr(epoch)

            # Unfreeze backbone after warmup
            if epoch == self.cfg.training.warmup_epochs:
                if hasattr(self.model, "freeze_backbone"):
                    for p in self.model.parameters():
                        p.requires_grad = True
                    logger.info("Backbone unfrozen — fine-tuning all layers.")
                    self.optimizer = optim.AdamW(
                        self.model.parameters(),
                        lr=self.cfg.training.learning_rate / 10,
                        weight_decay=self.cfg.training.weight_decay,
                    )

            train_metrics = self.train_epoch(epoch)
            val_metrics = evaluate(self.model, self.loaders["val"], self.device, self.criterion)

            if epoch >= self.cfg.training.warmup_epochs:
                self.scheduler.step()

            self.history["train"].append(train_metrics)
            self.history["val"].append(val_metrics)

            logger.info(
                f"Epoch {epoch+1:02d} | "
                f"Train loss={train_metrics['loss']:.4f} acc={train_metrics['accuracy']:.4f} | "
                f"Val loss={val_metrics['loss']:.4f} acc={val_metrics['accuracy']:.4f} "
                f"AUC={val_metrics['auc']:.4f} F1={val_metrics['f1']:.4f}"
            )

            # Checkpoint
            if val_metrics["auc"] > self.best_val_auc:
                self.best_val_auc = val_metrics["auc"]
                self.patience_counter = 0
                self._save_checkpoint(epoch, val_metrics)
                logger.info(f"  ✓ New best AUC: {self.best_val_auc:.4f}")
            else:
                self.patience_counter += 1
                if self.patience_counter >= self.cfg.training.early_stopping_patience:
                    logger.info("Early stopping triggered.")
                    break

        self._final_evaluation()

    def _save_checkpoint(self, epoch: int, metrics: dict):
        ckpt_path = self.ckpt_dir / f"{self.run_name}_best.pt"
        torch.save({
            "epoch": epoch,
            "model_state_dict": self.model.state_dict(),
            "optimizer_state_dict": self.optimizer.state_dict(),
            "metrics": metrics,
            "config": self.cfg,
            "run_name": self.run_name,
        }, ckpt_path)
        logger.info(f"  Checkpoint saved: {ckpt_path}")

    def _final_evaluation(self):
        logger.info("\n=== Final Test Evaluation ===")
        test_metrics = evaluate(self.model, self.loaders["test"], self.device, self.criterion)
        logger.info(
            f"Test accuracy={test_metrics['accuracy']:.4f} "
            f"AUC={test_metrics['auc']:.4f} F1={test_metrics['f1']:.4f}"
        )

        history_path = self.ckpt_dir / f"{self.run_name}_history.json"
        with open(history_path, "w") as f:
            json.dump({"train": self.history["train"], "val": self.history["val"], "test": test_metrics}, f, indent=2)
        logger.info(f"Training history saved: {history_path}")


if __name__ == "__main__":
    import argparse

    parser = argparse.ArgumentParser(description="Train deepfake detector")
    parser.add_argument("--data", default="./data/processed", help="Preprocessed face dataset root")
    parser.add_argument("--arch", default="efficientnet_b4", choices=["efficientnet_b4", "xception", "resnet18"])
    parser.add_argument("--epochs", type=int, default=20)
    parser.add_argument("--batch-size", type=int, default=32)
    parser.add_argument("--lr", type=float, default=1e-4)
    args = parser.parse_args()

    cfg = DEFAULT_CONFIG
    cfg.data.dataset_root = args.data
    cfg.model.architecture = args.arch
    cfg.training.num_epochs = args.epochs
    cfg.training.batch_size = args.batch_size
    cfg.training.learning_rate = args.lr

    trainer = Trainer(cfg)
    trainer.build()
    trainer.train()
